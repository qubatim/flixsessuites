---
import { Icon } from "astro-icon/components";

const links = [
  { href: "/", label: "Home" },
  { href: "/suites", label: "Suites" },
  { href: "/facilities", label: "Facilities" },
  { href: "/gallery", label: "Gallery" },
  { href: "/contact", label: "Contact" },
  { href: "/blog", label: "Blog" },
];
---

<header
  class="sticky top-0 z-50 border-b border-border bg-background/95 backdrop-blur"
  x-data="{ mobileMenuOpen: false }"
>
  <nav
    class="mx-auto flex max-w-[1280px] items-center justify-between px-5 py-4 md:px-8"
  >
    <a href="/" class="block">
      <img src="/logo.svg" alt="Flixses Suites Logo" class="h-auto w-[140px]" />
    </a>

    <!-- Desktop Navigation -->
    <ul class="hidden items-center gap-6 text-primary md:flex">
      {
        links.map((link) => (
          <li>
            <a href={link.href} class="transition hover:text-accent">
              {link.label}
            </a>
          </li>
        ))
      }
      <li>
        <a
          href="/contact"
          class="flex items-center gap-2 rounded-md border border-secondary bg-secondary px-5 py-2.5 font-medium text-white transition hover:bg-primary hover:border-primary"
        >
          Book Your Stay
          <Icon name="hugeicons:calendar-add-01" class="text-lg" />
        </a>
      </li>
    </ul>

    <!-- Mobile Menu Toggle -->
    <button
      class="flex items-center text-primary md:hidden p-2"
      @click="mobileMenuOpen = true"
      aria-label="Toggle menu"
    >
      <Icon name="hugeicons:menu-01" class="text-3xl" />
    </button>
  </nav>

  <!-- Mobile Menu Drawer -->
  <div
    class="fixed inset-0 z-100 bg-background md:hidden"
    x-show="mobileMenuOpen"
    x-cloak
    x-transition:enter="transition ease-out duration-300"
    x-transition:enter-start="opacity-0 translate-y-4"
    x-transition:enter-end="opacity-100 translate-y-0"
    x-transition:leave="transition ease-in duration-300"
    x-transition:leave-start="opacity-100 translate-y-0"
    x-transition:leave-end="opacity-0 translate-y-4"
  >
    <div class="absolute right-5 top-5">
      <button
        class="p-2 text-primary transition hover:text-secondary"
        @click="mobileMenuOpen = false"
        aria-label="Close menu"
      >
        <Icon name="hugeicons:cancel-01" class="text-3xl" />
      </button>
    </div>
    <div
      class="flex h-full flex-col items-center justify-center gap-8 text-center px-5"
    >
      {
        links.map((link) => (
          <a
            href={link.href}
            class="font-display text-3xl text-primary transition hover:text-secondary"
            @click="mobileMenuOpen = false"
          >
            {link.label}
          </a>
        ))
      }
      <a
        href="/contact"
        class="mt-6 flex items-center gap-2 rounded-md bg-[#A0844C] px-10 py-4 text-lg font-medium tracking-wide text-white transition hover:bg-[#383A40]"
        @click="mobileMenuOpen = false"
      >
        Book Your Stay <Icon name="hugeicons:calendar-add-01" class="text-xl" />
      </a>
    </div>
  </div>
</header>

<style>
  [x-cloak] {
    display: none !important;
  }
</style>
