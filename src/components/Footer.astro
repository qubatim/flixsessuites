---
import { Icon } from "astro-icon/components";
---

<footer class="bg-slate-800 text-white py-20 relative">
  <div class="mx-auto max-w-[1280px] px-5 md:px-8">
    <div
      class="grid grid-cols-1 md:grid-cols-4 gap-12 lg:gap-16 border-b border-white/10 pb-16"
    >
      <!-- Logo & About -->
      <div class="md:col-span-2 flex flex-col gap-6 text-center md:text-left">
        <a href="/" class="inline-block mx-auto md:mx-0">
          <img
            src="/logo.svg"
            alt="Flixses Suites Logo"
            class="h-auto w-[160px] brightness-0 invert"
          />
        </a>
        <p
          class="text-white/60 max-w-sm text-sm leading-relaxed mt-2 mx-auto md:mx-0 font-light"
        >
          Flixses Suites is an oasis of refined hospitality, pairing modern
          elegance with unparalleled comfort in the heart of Kuala Lumpur.
        </p>
      </div>

      <!-- Quick Links -->
      <div class="flex flex-col gap-5 text-center md:text-left">
        <h4
          class="font-display font-semibold text-lg tracking-widest text-accent uppercase relative after:content-[''] after:absolute after:bottom-[-8px] after:left-1/2 md:after:left-0 after:-ml-3 md:after:ml-0 after:w-6 after:h-px after:bg-accent"
        >
          Explore
        </h4>
        <nav class="flex flex-col gap-4 text-sm text-white/70 mt-3 font-light">
          <a href="/" class="transition hover:text-white hover:translate-x-1"
            >Home</a
          >
          <a
            href="/suites"
            class="transition hover:text-white hover:translate-x-1"
            >Our Suites</a
          >
          <a
            href="/facilities"
            class="transition hover:text-white hover:translate-x-1"
            >Facilities</a
          >
          <a
            href="/gallery"
            class="transition hover:text-white hover:translate-x-1">Gallery</a
          >
          <a
            href="/contact"
            class="transition hover:text-white hover:translate-x-1"
            >Contact Us</a
          >
        </nav>
      </div>

      <!-- Contact Info -->
      <div class="flex flex-col gap-5 text-center md:text-left">
        <h4
          class="font-display font-semibold text-lg tracking-widest text-accent uppercase relative after:content-[''] after:absolute after:bottom-[-8px] after:left-1/2 md:after:left-0 after:-ml-3 md:after:ml-0 after:w-6 after:h-px after:bg-accent"
        >
          Say Hello
        </h4>
        <div class="flex flex-col gap-4 text-sm text-white/70 mt-3 font-light">
          <p class="flex items-center justify-center md:justify-start gap-3">
            <Icon name="hugeicons:location-01" class="text-lg text-accent" />
            Kuala Lumpur, Malaysia
          </p>
          <a href="mailto:info@flixsessuites.com" class="flex items-center justify-center md:justify-start gap-3 transition hover:text-white">
            <Icon name="hugeicons:mail-01" class="text-lg text-accent" />
            info@flixsessuites.com
          </a>
          <a href="tel:+6012345678" class="flex items-center justify-center md:justify-start gap-3 transition hover:text-white">
            <Icon name="hugeicons:call" class="text-lg text-accent" />
            +60 12 345 678
          </a>
        </div>
      </div>
    </div>

    <!-- Copyright -->
    <div
      class="mt-8 flex flex-col items-center justify-between gap-4 text-xs font-light tracking-wide text-white/40 md:flex-row"
    >
      <p>© {new Date().getFullYear()} Flixses Suites. All rights reserved.</p>
      <div class="flex gap-6">
        <a href="#" class="transition hover:text-white">Privacy Policy</a>
        <a href="#" class="transition hover:text-white">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>
