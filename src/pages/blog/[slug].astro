---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { baseJsonLd, breadcrumbJsonLd } from "../../lib/seo";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.data.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const jsonLd = [
  ...baseJsonLd,
  breadcrumbJsonLd([
    { name: "Home", url: "https://flixsessuites.com/" },
    { name: "Blog", url: "https://flixsessuites.com/blog" },
    {
      name: post.data.title,
      url: `https://flixsessuites.com/blog/${post.data.slug}`,
    },
  ]),
  {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    headline: post.data.title,
    datePublished: new Date(post.data.date).toISOString(),
    description: post.data.description,
    url: `https://flixsessuites.com/blog/${post.data.slug}`,
    publisher: { "@type": "Organization", name: "Flixes Suites" },
  },
];
---

<BaseLayout
  title={`${post.data.title} | Flixes Suites Blog`}
  description={post.data.description}
  path={`/blog/${post.data.slug}`}
  type="article"
  jsonLd={jsonLd}
>
  <Header />
  <main class="mx-auto max-w-4xl px-5 py-16 md:px-8">
    <p class="text-xs text-secondary uppercase tracking-[0.2em] text-gold">
      {new Date(post.data.date).toLocaleDateString("en-US")}
    </p>
    <h1
      class="mt-3 font-display text-4xl text-primary leading-tight md:text-6xl"
    >
      {post.data.title}
    </h1>
    <article
      class="prose prose-neutral mt-10 max-w-none prose-headings:font-display prose-a:text-gold prose-img:rounded-xl"
    >
      <Content />
    </article>
  </main>
  <Footer />
</BaseLayout>
