---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { baseJsonLd, breadcrumbJsonLd } from "../../lib/seo";

const posts = (await getCollection("blog")).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
);

const jsonLd = [
  ...baseJsonLd,
  breadcrumbJsonLd([
    { name: "Home", url: "https://flixsessuites.com/" },
    { name: "Blog", url: "https://flixsessuites.com/blog" },
  ]),
  {
    "@context": "https://schema.org",
    "@type": "Blog",
    name: "Flixes Suites Blog",
    url: "https://flixsessuites.com/blog",
  },
];
---

<BaseLayout
  title="Blog | Flixes Suites"
  description="Travel tips, destination guides, and hospitality insights from Flixes Suites."
  path="/blog"
  jsonLd={jsonLd}
>
  <Header />
  <main class="mx-auto max-w-7xl px-5 py-20 md:px-8">
    <h1 class="hero-fade font-display text-5xl md:text-6xl">Blog</h1>
    <p class="hero-fade hero-fade-delay mt-4 max-w-2xl text-charcoal/80">Travel inspiration and practical guides for your Malaysia journey.</p>
    <div class="mt-12 grid gap-6 md:grid-cols-2">
      {
        posts.map((post) => (
          <article class="reveal rounded-2xl border border-sand bg-white p-6 shadow-sm">
            <p class="text-xs uppercase tracking-[0.2em] text-gold">{new Date(post.data.date).toLocaleDateString("en-US")}</p>
            <h2 class="mt-3 font-display text-3xl">{post.data.title}</h2>
            <p class="mt-4 text-sm leading-7 text-charcoal/80">{post.data.description}</p>
            <a href={`/blog/${post.data.slug}`} class="mt-5 inline-block text-sm font-semibold text-gold transition hover:text-charcoal">Read article</a>
          </article>
        ))
      }
    </div>
  </main>
  <Footer />
</BaseLayout>
