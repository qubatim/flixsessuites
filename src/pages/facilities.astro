---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import PageHero from "../components/PageHero.astro";
import { baseJsonLd, breadcrumbJsonLd } from "../lib/seo";
import { Icon } from "astro-icon/components";

const jsonLd = [
  ...baseJsonLd,
  breadcrumbJsonLd([
    { name: "Home", url: "https://flixsessuites.com/" },
    { name: "Facilities", url: "https://flixsessuites.com/facilities" },
  ]),
];
---

<BaseLayout
  title="Facilities | Flixes Suites"
  description="Explore in-room and property-wide facilities including fitness center, rooftop pool, and premium guest amenities."
  path="/facilities"
  jsonLd={jsonLd}
>
  <Header />
  <main>
    <PageHero
      title="Thoughtful amenities"
      subtitle="Everything you need for a comfortable, elevated city stay."
      image="/images/IMG_6342.jpg"
    />
    <section class="mx-auto max-w-[1280px] px-5 py-24 md:px-8">
      <div class="grid gap-12 lg:grid-cols-2">
        <div
          class="reveal rounded-md border border-border bg-background p-10 shadow-sm transition hover:shadow-soft"
        >
          <p class="text-xs uppercase tracking-[0.3em] text-accent">
            In-Room Facilities
          </p>
          <h2 class="mt-4 font-bold font-display text-primary text-4xl">
            Comfort & convenience
          </h2>
          <ul class="mt-8 grid grid-cols-1 gap-4 text-sm sm:grid-cols-2">
            <li class="flex items-center gap-3">
              <Icon
                name="hugeicons:washing-machine"
                class="text-secondary text-2xl"
              /> Washing machine
            </li>
            <li class="flex items-center gap-3">
              <Icon name="hugeicons:t-shirt" class="text-secondary text-2xl" /> Iron
            </li>
            <li class="flex items-center gap-3">
              <Icon name="hugeicons:fridge" class="text-secondary text-2xl" /> Refrigerator
            </li>
            <li class="flex items-center gap-3">
              <Icon name="hugeicons:wifi-01" class="text-secondary text-2xl" /> Complimentary
              Wi-Fi
            </li>
            <li class="flex items-center gap-3">
              <Icon
                name="hugeicons:hair-dryer"
                class="text-secondary text-2xl"
              /> Hair dryer
            </li>
            <li class="flex items-center gap-3">
              <Icon name="hugeicons:clean" class="text-secondary text-2xl" /> Housekeeping
            </li>
            <li class="flex items-center gap-3">
              <Icon
                name="hugeicons:fast-wind"
                class="text-secondary text-2xl"
              /> Air conditioning
            </li>
            <li class="flex items-center gap-3">
              <Icon
                name="hugeicons:thermometer"
                class="text-secondary text-2xl"
              /> Heating
            </li>
            <li class="flex items-center gap-3">
              <Icon name="hugeicons:kettle" class="text-secondary text-2xl" /> Electric
              kettle
            </li>
            <li class="flex items-center gap-3">
              <Icon name="hugeicons:tv-01" class="text-secondary text-2xl" /> Satellite
              flat-screen TV
            </li>
          </ul>
        </div>
        <div
          class="reveal rounded-md border border-border bg-background p-10 shadow-sm transition hover:shadow-soft"
        >
          <p class="text-xs uppercase tracking-[0.3em] text-accent">
            Hotel Facilities
          </p>
          <h2 class="mt-4 font-bold font-display text-primary text-4xl">
            Across the property
          </h2>
          <ul class="mt-8 grid grid-cols-1 gap-4 text-sm sm:grid-cols-2">
            <li class="flex items-center gap-3">
              <Icon name="hugeicons:question" class="text-secondary text-2xl" /> 24-hour
              reception
            </li>
            <li class="flex items-center gap-3">
              <Icon
                name="hugeicons:treadmill-01"
                class="text-secondary text-2xl"
              /> Fitness center
            </li>
            <li class="flex items-center gap-3">
              <Icon
                name="hugeicons:parking-area-square"
                class="text-secondary text-2xl"
              /> Free parking
            </li>
            <li class="flex items-center gap-3">
              <Icon name="hugeicons:library" class="text-secondary text-2xl" /> Library
            </li>
            <li class="flex items-center gap-3">
              <Icon name="hugeicons:alert-01" class="text-secondary text-2xl" /> Non-smoking
              rooms
            </li>
            <li class="flex items-center gap-3">
              <Icon name="hugeicons:pool" class="text-secondary text-2xl" /> Outdoor
              swimming pool
            </li>
            <li class="flex items-center gap-3">
              <Icon name="hugeicons:wifi-01" class="text-secondary text-2xl" /> Wi-Fi
              access
            </li>
          </ul>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
