---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    name: "Page Not Found - Flixses Suites",
    description: "The page you are looking for does not exist.",
  },
];
---

<BaseLayout
  title="Page Not Found | Flixses Suites"
  description="The page you are looking for does not exist."
  jsonLd={jsonLd}
>
  <Header />
  <main
    class="flex min-h-[70vh] flex-col items-center justify-center px-5 text-center md:px-8"
  >
    <div class="reveal">
      <h1 class="font-display text-primary mb-6 text-6xl md:text-8xl">404</h1>
      <p class="text-secondary mb-10 max-w-md mx-auto text-lg">
        This page remains undiscovered. Return to our curated collections of
        luxury suites.
      </p>
      <a
        href="/"
        class="inline-block rounded-md border border-primary bg-primary px-8 py-3 text-sm text-background transition-colors hover:bg-accent hover:border-accent hover:text-primary"
      >
        Return Home
      </a>
    </div>
  </main>
  <Footer />
</BaseLayout>
